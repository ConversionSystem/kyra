{
  "git": {
    "deploymentEnabled": false
  },
  "ignoreCommand": "exit 1",
  "functions": {
    "app/api/agency/sites/[id]/build/route.ts": { "maxDuration": 300 },
    "app/api/agency/sites/[id]/generate/route.ts": { "maxDuration": 300 },
    "app/api/agency/sites/[id]/deploy/route.ts": { "maxDuration": 300 },
    "app/api/agency/sites/[id]/growth/route.ts": { "maxDuration": 60 },
    "app/api/agency/sites/[id]/pages/route.ts": { "maxDuration": 60 }
  },
  "crons": [
    {
      "path": "/api/ghl/poll",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/weekly-report",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/email-sequence",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/follow-ups",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/crm-autopilot",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/briefing?secret=CRON_SECRET_PLACEHOLDER",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/seo-worker",
      "schedule": "0 6 * * 1-5"
    },
    {
      "path": "/api/cron/alerts",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/terminal-credits",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/gateway-token-sync",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/usage-alerts",
      "schedule": "0 8 * * *"
    }
  ]
}
