# Kyra Environment Variables
# Copy this file to .env.local and fill in values

# =====================================================
# APP
# =====================================================
NEXT_PUBLIC_APP_URL=https://kyra.conversionsystem.com
NEXT_PUBLIC_APP_NAME=Kyra

# =====================================================
# SUPABASE
# =====================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =====================================================
# KYRA WORKER (Multi-tenant Cloudflare Sandboxes)
# =====================================================
KYRA_WORKER_URL=https://kyra-worker.your-domain.workers.dev
KYRA_API_SECRET=your-kyra-api-secret

# =====================================================
# OPENCLAW GATEWAY (Legacy — Mac mini tunnel)
# =====================================================
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_API_KEY=your-openclaw-api-key

# =====================================================
# FEATURE FLAGS
# =====================================================
# Route chat through Kyra Worker (true/false) — recommended, takes priority
KYRA_USE_WORKER=true
# Route chat through OpenClaw Gateway on Mac mini (true/false) — legacy fallback
KYRA_USE_OPENCLAW=false
# Enable OpenClaw skill ecosystem — web search, file ops, sub-agents (true/false)
KYRA_OPENCLAW_SKILLS=false

# =====================================================
# AI MODELS (Used by OpenClaw)
# =====================================================
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx

# =====================================================
# PINECONE (Vector Memory)
# =====================================================
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX=kyra-memories

# =====================================================
# STRIPE (Billing)
# =====================================================
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Stripe Price IDs (create in Stripe Dashboard)
STRIPE_STARTER_PRICE_ID=price_xxx
STRIPE_PRO_PRICE_ID=price_yyy
STRIPE_SCALE_PRICE_ID=price_zzz
STRIPE_PER_CLIENT_PRICE_ID=price_www

# =====================================================
# SLACK (Integration)
# =====================================================
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_SIGNING_SECRET=your-slack-signing-secret

# =====================================================
# GOOGLE (Calendar Integration)
# =====================================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# =====================================================
# BRAVE SEARCH (Web Search)
# =====================================================
BRAVE_API_KEY=your-brave-api-key

# =====================================================
# CRON (Reminder Delivery)
# =====================================================
CRON_API_KEY=your-cron-api-key
